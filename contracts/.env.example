# Fat Punks contracts/deploy env
#
# These values are PRIVATE and are used by Foundry tests, deploy scripts,
# verification, and fork simulations. Local contracts/.env files are ignored.

PK=
DEPLOYER_ADDRESS=0x0000000000000000000000000000000000000000
SEPOLIA_RPC_URL=
MAINNET_RPC_URL=
ETHERSCAN_API_KEY=

# Only set this in the shell for an intentional mainnet deploy command.
I_UNDERSTAND_THIS_IS_MAINNET=0
